<Application x:Class="HomeInventory.Desktop.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HomeInventory.Desktop.Wpf"
             xmlns:vm="clr-namespace:HomeInventory.Desktop.Wpf.ViewModels"
             xmlns:views="clr-namespace:HomeInventory.Desktop.Wpf.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Lime" />

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />

            </ResourceDictionary.MergedDictionaries>
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                    <views:LoginView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ItemsSearchViewModel}">
                <views:ItemsSearchView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:TopBarViewModel}">
                <views:TopBarView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:MainViewModel}">
                <views:MainView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:LocationTreeViewModel}">
                <views:LocationTreeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RightPaneViewModel}">
                <views:RightPaneView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
